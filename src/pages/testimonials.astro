---
import BaseLayout from '../layouts/BaseLayout.astro';
import ContactBand from '../components/ContactBand.astro';
import PageHero from '../components/PageHero.astro';
import { testimonials } from '../data/site';
---

<BaseLayout title="Testimonials">
  <PageHero title="Testimonials" image="assets/hero-testimonials.jpg" compact />

  <section class="section testimonials-section">
    <div class="container testimonials-grid">
      {testimonials.map((quote) => (
        <blockquote class="testimonial-card reveal flip">
          <p>“{quote}”</p>
        </blockquote>
      ))}
    </div>
    <div class="container note reveal">
      <p>*Originals of testimonials available upon request.</p>
    </div>
  </section>

  <ContactBand />
</BaseLayout>

<style>
  .testimonials-section {
    background: #fff;
  }

  .testimonials-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 28px;
  }

  .testimonial-card {
    margin: 0;
    border-left: 5px solid var(--sss-gold);
    background: var(--sss-soft);
    box-shadow: 0 12px 32px rgba(0, 0, 0, 0.08);
    padding: clamp(24px, 4vw, 34px);
  }

  .testimonial-card p {
    margin: 0;
    color: #555;
    font-size: 1rem;
    line-height: 1.85;
  }

  .note {
    margin-top: 44px;
    background: #fff;
  }

  .note p {
    margin: 0;
    color: #555;
    font-size: 1.25rem;
    line-height: 1.5;
    text-align: justify;
  }

  @media (max-width: 760px) {
    .testimonials-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
