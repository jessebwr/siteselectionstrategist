---
import { contact } from '../data/site';
import { asset } from '../utils/paths';
---

<section class="contact-band section compact">
  <div class="contact-frame reveal">
    <div class="contact-bg" aria-hidden="true">
      <img src={asset('assets/about-core.jpg')} alt="" />
    </div>
    <div class="contact-content">
      <div class="contact-heading">
        <h2>LET'S CONNECT</h2>
        <a href={contact.phoneHref}>{contact.phoneDisplay}</a>
      </div>
      <div class="contact-card">
        <h3>Contact Us</h3>
        <p>{contact.location}</p>
        <p>{contact.reach}</p>
        <a href={`mailto:${contact.email}`}>{contact.email}</a>
      </div>
    </div>
  </div>
</section>

<style>
  .contact-band {
    background: linear-gradient(#fff 0 24%, #202020 24% 100%);
  }

  .contact-frame {
    position: relative;
    width: var(--content);
    min-height: 380px;
    margin: 0 auto;
    border: 8px solid rgba(32, 32, 32, 0.18);
    background: #fff;
    box-shadow: 0 18px 70px rgba(0, 0, 0, 0.15);
    overflow: hidden;
  }

  .contact-bg {
    position: absolute;
    inset: 58px -90px 0 -90px;
    opacity: 0.34;
  }

  .contact-bg img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .contact-content {
    position: relative;
    z-index: 1;
    display: grid;
    min-height: 360px;
    align-items: center;
    padding: clamp(28px, 5vw, 58px);
  }

  .contact-heading {
    max-width: 760px;
    margin: 0 auto 26px;
    text-align: left;
  }

  h2 {
    margin: 0;
    color: #282828;
    font-family: "Playfair Display", Georgia, serif;
    font-size: clamp(2.1rem, 7vw, 4.6rem);
    line-height: 1;
  }

  .contact-heading a {
    color: var(--sss-gold);
    font-family: Poppins, Helvetica, Arial, sans-serif;
    font-size: clamp(1.15rem, 3vw, 1.8rem);
    font-weight: 700;
    letter-spacing: 0.05em;
  }

  .contact-card {
    width: min(720px, 100%);
    margin: 0 auto;
    border-top: 7px solid var(--sss-gold);
    background: #3a3a3a;
    color: #fff;
    padding: clamp(26px, 5vw, 42px);
    text-align: center;
  }

  h3 {
    margin: 0 0 14px;
    font-size: 1.15rem;
    letter-spacing: 0.08em;
  }

  p {
    margin: 0 0 14px;
    font-weight: 700;
    letter-spacing: 0.04em;
  }

  .contact-card a {
    color: #fff;
    font-weight: 700;
    letter-spacing: 0.04em;
    overflow-wrap: anywhere;
  }

  @media (max-width: 720px) {
    .contact-frame {
      width: calc(100vw - 24px);
      border-width: 5px;
    }

    .contact-bg {
      inset: 124px 0 0;
      opacity: 0.28;
    }

    .contact-content {
      min-height: 320px;
      padding: 26px 18px 30px;
    }

    .contact-heading {
      margin-bottom: 24px;
      text-align: center;
    }

    .contact-heading a {
      display: inline-flex;
      margin-top: 10px;
      background: #202020;
      color: #fff;
      padding: 7px 12px;
      font-size: 1.02rem;
      letter-spacing: 0.04em;
      line-height: 1.2;
    }
  }
</style>
