---
import { asset } from '../utils/paths';

interface Props {
  eyebrow?: string;
  title: string;
  image: string;
  compact?: boolean;
}

const { eyebrow, title, image, compact = false } = Astro.props;
---

<section class:list={['page-hero', compact && 'compact']}>
  <img src={asset(image)} alt="" />
  <div class="overlay"></div>
  <div class="container hero-copy reveal is-visible">
    {eyebrow && <p class="eyebrow">{eyebrow}</p>}
    <h1>{title}</h1>
  </div>
</section>

<style>
  .page-hero {
    position: relative;
    display: grid;
    min-height: clamp(420px, 58vw, 690px);
    align-items: center;
    overflow: hidden;
    background: #222;
  }

  .page-hero.compact {
    min-height: clamp(280px, 36vw, 430px);
  }

  img,
  .overlay {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }

  img {
    object-fit: cover;
    object-position: center;
  }

  .overlay {
    background: rgba(0, 0, 0, 0.62);
  }

  .hero-copy {
    position: relative;
    z-index: 1;
    text-align: right;
  }

  h1 {
    margin: 0;
    color: #fff;
    font-family: "Playfair Display", Georgia, serif;
    font-size: clamp(2.4rem, 6.4vw, 4.8rem);
    font-weight: 700;
    letter-spacing: 0.04em;
    line-height: 1.1;
    text-transform: uppercase;
  }

  .eyebrow {
    margin: 0 0 6px;
    font-size: clamp(0.95rem, 2vw, 1.35rem);
  }

  @media (max-width: 720px) {
    .hero-copy {
      text-align: left;
    }
  }
</style>
