---
import { ClientRouter } from 'astro:transitions';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { asset } from '../utils/paths';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = 'Hotel site selection partner and advocate for meeting planners.',
} = Astro.props;

const pageTitle = title.includes('SiteSelectionStrategist')
  ? title
  : `${title} | SiteSelectionStrategist`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{pageTitle}</title>
    <link rel="icon" type="image/png" href={asset('assets/logo-mono-small.png')} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Lato:wght@300;400;700;900&family=Playfair+Display:wght@700&family=Poppins:wght@500;600;700&family=Raleway:wght@600;700&display=swap"
      rel="stylesheet"
    />
    <ClientRouter />
  </head>
  <body>
    <Header />
    <main class="site-main">
      <slot />
    </main>
    <Footer />
    <script>
      const shrinkHeaderAt = 84;
      const expandHeaderAt = 12;
      let ticking = false;

      const getHeader = () => document.querySelector('[data-site-header]');
      const getToggle = () => document.querySelector('[data-menu-toggle]');
      const getMenu = () => document.querySelector('[data-mobile-menu]');

      const updateHeader = () => {
        const header = getHeader();

        if (!header) {
          ticking = false;
          return;
        }

        const isScrolled = header.classList.contains('is-scrolled');

        if (!isScrolled && window.scrollY > shrinkHeaderAt) {
          header.classList.add('is-scrolled');
        } else if (isScrolled && window.scrollY < expandHeaderAt) {
          header.classList.remove('is-scrolled');
        }

        ticking = false;
      };

      const requestHeaderUpdate = () => {
        if (!ticking) {
          window.requestAnimationFrame(updateHeader);
          ticking = true;
        }
      };

      const closeMenu = () => {
        document.body.classList.remove('menu-open');
        getToggle()?.setAttribute('aria-expanded', 'false');
        getMenu()?.setAttribute('data-open', 'false');
      };

      const toggleMenu = (toggle: Element) => {
        const menu = getMenu();
        const isOpen = toggle.getAttribute('aria-expanded') === 'true';
        document.body.classList.toggle('menu-open', !isOpen);
        toggle.setAttribute('aria-expanded', String(!isOpen));
        menu?.setAttribute('data-open', String(!isOpen));
      };

      const handleDocumentClick = (event: MouseEvent) => {
        if (!(event.target instanceof Element)) return;

        const toggle = event.target.closest('[data-menu-toggle]');

        if (toggle) {
          toggleMenu(toggle);
          return;
        }

        if (event.target.closest('[data-mobile-menu] a')) {
          closeMenu();
        }
      };

      const reveal = () => {
        const observer = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                entry.target.classList.add('is-visible');
                observer.unobserve(entry.target);
              }
            });
          },
          { threshold: 0.14, rootMargin: '0px 0px -8% 0px' },
        );

        document.querySelectorAll('.reveal').forEach((el) => observer.observe(el));
      };

      const root = document.documentElement;

      if (root.dataset.sssScrollBound !== 'true') {
        window.addEventListener('scroll', requestHeaderUpdate, { passive: true });
        root.dataset.sssScrollBound = 'true';
      }

      if (root.dataset.sssClickBound !== 'true') {
        document.addEventListener('click', handleDocumentClick);
        root.dataset.sssClickBound = 'true';
      }

      if (root.dataset.sssPageLoadBound !== 'true') {
        document.addEventListener('astro:page-load', () => {
          closeMenu();
          updateHeader();
          reveal();
        });
        root.dataset.sssPageLoadBound = 'true';
      }

      if (root.dataset.sssVisibilityBound !== 'true') {
        const recoverHeader = () => {
          ticking = false;
          updateHeader();
        };

        document.addEventListener('visibilitychange', () => {
          if (!document.hidden) recoverHeader();
        });
        window.addEventListener('focus', recoverHeader);
        window.addEventListener('pageshow', recoverHeader);
        root.dataset.sssVisibilityBound = 'true';
      }

      updateHeader();
      reveal();
    </script>
  </body>
</html>
